# Azure/GitHub Models Token
# Get from: https://github.com/marketplace/models
GITHUB_TOKEN=your_github_token_here

# RAWG API Key
# Get from: https://rawg.io/apidocs (free, no credit card required)
RAWG_API_KEY=your_rawg_api_key_here

# IGDB API Credentials (via Twitch)
# Get from: https://dev.twitch.tv/console/apps (free)
IGDB_CLIENT_ID=your_igdb_client_id_here
IGDB_CLIENT_SECRET=your_igdb_client_secret_here

# Optional: Use OpenAI directly instead of Azure
# OPENAI_API_KEY=your_openai_api_key_here
